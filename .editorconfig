root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.java]
indent_style = space
indent_size = 2
continuation_indent_size = 4
max_line_length = 100

[*.{xml,pom}]
indent_style = tab
indent_size = 4

[*.{yml,yaml,json,md,sql}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd,ps1}]
end_of_line = crlf
